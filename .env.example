# Root environment for local docker compose setup

# Caddy hostnames for local TLS routing
CADDY_HOSTS=git.local, localhost

# Legacy static Caddy basic auth (Phase 0 fallback / rollback)
# Use: docker run --rm caddy:2-alpine caddy hash-password --plaintext '<password>'
CADDY_BASIC_AUTH_USERNAME=gituser
CADDY_BASIC_AUTH_HASH=$$2a$$14$$hev0bkQ/dOAgNjtwwaMI5.JPVUihUH5wwC/vMuUBq4/W6k6L7R8My

# Backend service settings (used in future phases)
BACKEND_PORT=4000
NODE_ENV=development
JWT_SECRET=replace-me-in-local-env
BCRYPT_COST=12
# Disable auth rate limiting for compose-based E2E runs only (never enable in production)
DISABLE_AUTH_RATE_LIMIT=true

# Frontend service settings
VITE_API_BASE_URL=https://localhost/api

# Database settings (used in future phases)
POSTGRES_DB=git_platform
POSTGRES_USER=git_platform
POSTGRES_PASSWORD=replace-me-in-local-env
DATABASE_URL=postgresql://git_platform:replace-me-in-local-env@postgres:5432/git_platform

# Shared data mount paths
REPOS_PATH=/git-repos
KEYS_PATH=/data/keys/authorized_keys

# Test database (used by backend Vitest integration tests; separate from dev DB)
DATABASE_URL_TEST=postgresql://git_platform:replace-me-in-local-env@localhost:5433/git_platform_test

# Local dev seed credentials (created by pnpm db:seed)
SEED_USER_USERNAME=devuser
SEED_USER_EMAIL=dev@example.com
SEED_USER_PASSWORD=devpassword
